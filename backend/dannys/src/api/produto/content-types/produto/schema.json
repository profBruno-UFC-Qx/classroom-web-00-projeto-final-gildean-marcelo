{
  "kind": "collectionType",
  "collectionName": "produtos",
  "info": {
    "singularName": "produto",
    "pluralName": "produtos",
    "displayName": "Produto"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "descricao": {
      "type": "text"
    },
    "preco": {
      "type": "decimal",
      "required": true
    },
    "imagem_url": {
      "type": "string"
    },
    "situacao": {
      "type": "enumeration",
      "default": "ativo",
      "enum": [
        "ativo",
        "pausado"
      ]
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria",
      "inversedBy": "produtos"
    },
    "item_pedidos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item-pedido.item-pedido",
      "mappedBy": "produto"
    }
  }
}
