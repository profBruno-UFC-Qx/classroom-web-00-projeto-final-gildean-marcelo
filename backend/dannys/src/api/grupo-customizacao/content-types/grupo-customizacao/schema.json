{
  "kind": "collectionType",
  "collectionName": "grupo_customizacaos",
  "info": {
    "singularName": "grupo-customizacao",
    "pluralName": "grupo-customizacaos",
    "displayName": "GrupoCustomizacao"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "tipo_escolha": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "radio",
        "checkbox"
      ]
    },
    "min_escolhas": {
      "type": "integer",
      "default": 1
    },
    "max_escolhas": {
      "type": "integer",
      "required": true
    },
    "produto": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::produto.produto",
      "inversedBy": "grupo_customizacaos"
    },
    "opcao_customizacaos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::opcao-customizacao.opcao-customizacao",
      "mappedBy": "grupo_customizacao"
    }
  }
}
